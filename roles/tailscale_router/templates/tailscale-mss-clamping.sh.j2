#!/usr/bin/env bash
set -euo pipefail

IPTABLES=/usr/sbin/iptables
TAILSCALE_INTERFACE={{ tailscale_interface | quote }}

apply_rule() {
    local direction="$1"

    if ! "$IPTABLES" -t mangle -C FORWARD \
        "$direction" "$TAILSCALE_INTERFACE" \
        -p tcp --tcp-flags SYN,RST SYN \
        -j TCPMSS --clamp-mss-to-pmtu 2>/dev/null; then
        "$IPTABLES" -t mangle -A FORWARD \
            "$direction" "$TAILSCALE_INTERFACE" \
            -p tcp --tcp-flags SYN,RST SYN \
            -j TCPMSS --clamp-mss-to-pmtu
    fi
}

remove_rule() {
    local direction="$1"

    while "$IPTABLES" -t mangle -C FORWARD \
        "$direction" "$TAILSCALE_INTERFACE" \
        -p tcp --tcp-flags SYN,RST SYN \
        -j TCPMSS --clamp-mss-to-pmtu 2>/dev/null; do
        "$IPTABLES" -t mangle -D FORWARD \
            "$direction" "$TAILSCALE_INTERFACE" \
            -p tcp --tcp-flags SYN,RST SYN \
            -j TCPMSS --clamp-mss-to-pmtu
    done
}

case "${1:-apply}" in
    apply)
        apply_rule -o
        apply_rule -i
        ;;
    remove)
        remove_rule -o
        remove_rule -i
        ;;
    *)
        echo "Usage: $0 {apply|remove}" >&2
        exit 2
        ;;
esac
