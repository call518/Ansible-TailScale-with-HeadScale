[ req ]
prompt = no
distinguished_name = dn
x509_extensions = ca_ext

[ dn ]
C = {{ headscale_ca_dn.country }}
ST = {{ headscale_ca_dn.state }}
L = {{ headscale_ca_dn.locality }}
O = {{ headscale_ca_dn.organization }}
OU = {{ headscale_ca_dn.organizational_unit }}
CN = {{ headscale_ca_dn.common_name }}

[ ca_ext ]
basicConstraints = critical, CA:true
keyUsage = critical, keyCertSign, cRLSign
subjectKeyIdentifier = hash
authorityKeyIdentifier = keyid:always,issuer
