{
{% if headscale_router_tags_enabled | bool %}
  "tagOwners": {
{% for tag in headscale_router_tags.values() | unique %}
    "{{ tag }}": ["{{ headscale_user_name }}@"]{% if not loop.last %},{% endif %}
{% endfor %}
  },
{% endif %}
  "grants": [
    {
      "src": ["*"],
      "dst": ["*"],
      "ip": ["*"]
    }
  ]
}
